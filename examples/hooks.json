{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m codex_ble_buddy.cli approve-request --timeout 30 --auto-start-service",
            "timeout": 30,
            "statusMessage": "Checking approval request"
          }
        ]
      }
    ]
  }
}
